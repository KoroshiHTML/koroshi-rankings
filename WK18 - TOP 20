<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>TIENDAS + WEB · WK18</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#0d0d0d;--sur:#161616;--card:#1a1a1a;--bdr:#282828;--ah:#e8c44a;--am:#e84a7a;--wc:#34d399;--text:#f0f0f0;--mu:#666}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:"DM Sans",sans-serif;min-height:100vh}
header{background:var(--sur);border-bottom:1px solid var(--bdr);padding:13px 26px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;flex-wrap:wrap;gap:10px}
.logo{font-family:"Bebas Neue",sans-serif;font-size:22px;letter-spacing:4px}
.logo em{color:var(--ah);font-style:normal}
.hm{font-size:9px;color:var(--mu);letter-spacing:1.5px;text-transform:uppercase}
.tabs{display:flex;border-bottom:1px solid var(--bdr);background:var(--sur);padding:0 26px;overflow-x:auto}
.tab{padding:10px 18px;font-size:10px;letter-spacing:2px;text-transform:uppercase;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;color:var(--mu);transition:all .15s;white-space:nowrap}
.tab.active{color:var(--text);border-bottom-color:var(--ah)}
.tab.active.m{border-bottom-color:var(--am)}
.tab#tab-coming.active{border-bottom-color:var(--wc)}
.controls{padding:11px 26px;display:flex;gap:8px;flex-wrap:wrap;align-items:center;border-bottom:1px solid var(--bdr)}
.btn-grp{display:flex;gap:3px;flex-wrap:wrap}
.btn{padding:6px 14px;border:1px solid var(--bdr);background:transparent;color:var(--mu);font-family:"DM Sans",sans-serif;font-size:10px;font-weight:500;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;border-radius:2px;transition:all .15s}
.btn:hover{border-color:#555;color:var(--text)}
.btn.on-h{background:var(--ah);border-color:var(--ah);color:#000}
.btn.on-m{background:var(--am);border-color:var(--am);color:#fff}
.btn.on-ch{background:#2a2a2a;border-color:#555;color:var(--text)}
.sep{width:1px;background:var(--bdr);height:24px;margin:0 4px;align-self:center}
.badge{padding:4px 12px;border-radius:2px;font-family:"Bebas Neue",sans-serif;font-size:13px;letter-spacing:3px;margin-left:auto}
.bh{background:var(--ah);color:#000}.bm{background:var(--am);color:#fff}
.pdf-btn{padding:6px 12px;border:1px solid #444;background:#222;color:var(--text);font-size:10px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;border-radius:2px;font-family:"DM Sans",sans-serif}
.store-panel{padding:10px 26px;border-bottom:1px solid var(--bdr);display:none}
.store-select{background:var(--sur);color:var(--text);border:1px solid var(--bdr);padding:7px 12px;font-family:"DM Sans",sans-serif;font-size:12px;border-radius:2px;width:280px;cursor:pointer}
.store-select option{background:#111}
.store-controls{padding:10px 26px;display:flex;gap:8px;flex-wrap:wrap;align-items:center;border-bottom:1px solid var(--bdr);background:var(--sur)}
.store-subtabs{display:flex;border-bottom:1px solid var(--bdr);background:var(--sur);padding:0 26px;overflow-x:auto}
.stab{padding:9px 16px;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;border-bottom:2px solid transparent;color:var(--mu);transition:all .15s;white-space:nowrap}
.stab.active{color:var(--text);border-bottom-color:var(--ah)}
.stab.active.m{border-bottom-color:var(--am)}
.stab.active.wc{border-bottom-color:var(--wc)}
.summary{padding:9px 26px;display:flex;gap:20px;font-size:10px;color:var(--mu);letter-spacing:1px;text-transform:uppercase;background:var(--sur);border-bottom:1px solid var(--bdr);flex-wrap:wrap}
.summary strong{color:var(--text);font-size:11px}
.spark-wrap{padding:9px 26px 5px;border-bottom:1px solid var(--bdr)}
.spark-label{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--mu);margin-bottom:5px}
.spark-bars{display:flex;gap:2px;align-items:flex-end;height:28px}
.sbar{flex:1;border-radius:1px 1px 0 0;min-width:4px;position:relative}
.sbar::after{content:attr(data-tip);position:absolute;bottom:110%;left:50%;transform:translateX(-50%);background:#111;color:#fff;padding:3px 7px;font-size:9px;white-space:nowrap;border-radius:2px;pointer-events:none;z-index:99;opacity:0;transition:opacity .15s}
.sbar:hover::after{opacity:1}
.coming-banner{padding:10px 26px;background:rgba(52,211,153,.07);border-bottom:1px solid rgba(52,211,153,.2);display:none;align-items:center;gap:12px}
.coming-banner em{font-style:normal;font-family:"Bebas Neue",sans-serif;font-size:15px;letter-spacing:2px;color:var(--wc)}
.coming-banner span{font-size:10px;color:var(--mu);letter-spacing:1px}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:1px;background:var(--bdr)}
.card{background:var(--card);position:relative;overflow:hidden;transition:transform .18s,box-shadow .18s}
.card:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.6);z-index:2}
.card-img-wrap{width:100%;aspect-ratio:3/4;background:#1e1e1e;position:relative;overflow:hidden}
.card-img{width:100%;height:100%;object-fit:cover;display:block}
.rank{position:absolute;top:8px;left:8px;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:"Bebas Neue",sans-serif;font-size:14px;z-index:3}
.r1{background:#FFD700;color:#000;width:34px;height:34px;font-size:16px}
.r2{background:#C0C0C0;color:#000}.r3{background:#CD7F32;color:#000}
.rn{background:rgba(0,0,0,.8);color:var(--mu);border:1px solid #333}
.ly-tag{position:absolute;top:8px;right:8px;background:rgba(52,211,153,.85);color:#000;font-size:8px;font-weight:700;letter-spacing:1px;padding:3px 6px;border-radius:2px;z-index:3;text-transform:uppercase}
.card-body{padding:9px 11px 11px}
.card-ref{font-size:9px;color:var(--mu);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:2px}
.card-name{font-size:10px;font-weight:600;color:var(--text);margin-bottom:2px;line-height:1.3;text-transform:uppercase}
.card-fam{font-size:9px;color:var(--mu);margin-bottom:7px;text-transform:uppercase}
.card-stats{display:flex;justify-content:space-between;align-items:flex-end}
.sl{font-size:8px;color:var(--mu);letter-spacing:1px;text-transform:uppercase;margin-bottom:1px}
.sv{font-family:"Bebas Neue",sans-serif;font-size:15px;letter-spacing:.5px}
.sv.eh{color:var(--ah)}.sv.em{color:var(--am)}.sv.ewc{color:var(--wc)}
.sv.un{color:var(--text);font-size:12px}
.card-bar{position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--bdr)}
.cbh{height:2px;background:var(--ah)}.cbm{height:2px;background:var(--am)}.cbwc{height:2px;background:var(--wc)}
.fam-legend{padding:9px 26px;display:flex;gap:14px;font-size:10px;letter-spacing:1px;border-bottom:1px solid var(--bdr);background:var(--sur);align-items:center;flex-wrap:wrap}
.ldot{width:9px;height:9px;border-radius:50%;display:inline-block;margin-right:4px;vertical-align:middle}
.fam-sec{margin-bottom:1px}
.fam-hdr{padding:12px 26px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;border-bottom:1px solid var(--bdr);transition:background .15s;border-left:4px solid transparent;position:relative;overflow:hidden}
.fam-hdr:hover{background:#1e1e1e}
.fam-hdr.p80h{border-left-color:var(--ah);background:rgba(232,196,74,.04)}
.fam-hdr.p80m{border-left-color:var(--am);background:rgba(232,74,122,.04)}
.fam-hdr.p80wc{border-left-color:var(--wc);background:rgba(52,211,153,.04)}
.fam-bg{position:absolute;left:0;top:0;bottom:0;pointer-events:none}
.fam-left{display:flex;align-items:center;gap:12px;position:relative}
.fam-name{font-family:"Bebas Neue",sans-serif;font-size:16px;letter-spacing:2px}
.fam-name.dim{color:var(--mu)}
.fam-meta{display:flex;flex-direction:column;gap:2px}
.fam-pct{font-size:10px;letter-spacing:1px}
.fam-tag{font-size:8px;letter-spacing:1.5px;padding:2px 5px;border-radius:2px}
.tag-h{background:rgba(232,196,74,.15);color:var(--ah)}
.tag-m{background:rgba(232,74,122,.15);color:var(--am)}
.tag-wc{background:rgba(52,211,153,.15);color:var(--wc)}
.fam-right{display:flex;align-items:center;gap:10px;position:relative}
.fam-eur{font-family:"Bebas Neue",sans-serif;font-size:15px}
.fam-eur2{font-size:10px;color:var(--mu)}
.tog{font-size:10px;color:var(--mu);transition:transform .2s;margin-left:8px}
.fam-body{display:none;border-bottom:1px solid var(--bdr)}
.fam-body.open{display:block}
.no-data{padding:50px;text-align:center;color:var(--mu);font-size:13px;grid-column:1/-1}
.no-store{padding:60px 26px;text-align:center;color:var(--mu);font-size:14px}
#view-channel,#view-family,#view-coming{display:none}
@media print{
  body{background:#fff;color:#111}
  header,.tabs,.controls,.store-panel,.store-controls,.store-subtabs,.summary,.spark-wrap,.fam-legend,.coming-banner{display:none!important}
  .ph{display:flex!important}
  .card{background:#f5f5f5;border:1px solid #ddd;break-inside:avoid}
  .fam-hdr{background:#f0f0f0!important}
  .fam-body{display:block!important}
  .grid{gap:4px;background:#ccc}
  .rank{print-color-adjust:exact;-webkit-print-color-adjust:exact}
  @page{margin:12mm;size:A4 landscape}
}
.ph{display:none;justify-content:space-between;padding-bottom:10px;margin-bottom:12px;border-bottom:2px solid #111}
.ph-title{font-family:"Bebas Neue",sans-serif;font-size:22px;letter-spacing:4px}
.ph-meta{font-size:10px;color:#555;text-align:right;line-height:1.8}
</style>
</head>
