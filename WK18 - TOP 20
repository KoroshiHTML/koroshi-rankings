  const lyTag=mode==="wc"?'<div class="ly-tag">LY WK19+20</div>':"";
  const fam=item[F]?`<div class="card-fam">${item[F]}</div>`:"";
  return `<div class="card"><div class="card-img-wrap"><div class="rank ${rc}">${rank}</div>${lyTag}<img class="card-img" src="${item[PH]||purl(item[A],item[C])}" loading="lazy" onerror="this.style.display='none'"></div><div class="card-body"><div class="card-ref">${item[A]} · ${item[C]}</div><div class="card-name">${item[N]}</div>${fam}<div class="card-stats"><div><div class="sl">${mode==="wc"?"LY WK19+20":"TY WK18"}</div><div class="sv ${ec}">${fmt(eur)}</div></div><div style="text-align:right"><div class="sl">Units</div><div class="sv un">${fmtI(un)}</div></div></div></div><div class="card-bar"><div class="${bc}" style="width:${pct}%"></div></div></div>`;
}
function cardCompact(item,rank,isH,mode){
  const ec=mode==="wc"?"ewc":isH?"eh":"em",bc=mode==="wc"?"cbwc":isH?"cbh":"cbm";
  const eur=mode==="wc"?item[CEL]:item[CET],un=mode==="wc"?item[CUL]:item[CUT];
  const pct=Math.round((eur/(window._maxEur||eur))*100);
  const rc=rank===1?"r1":rank===2?"r2":rank===3?"r3":"rn";
  const lyTag=mode==="wc"?'<div class="ly-tag">LY WK19+20</div>':"";
  return `<div class="card"><div class="card-img-wrap"><div class="rank ${rc}">${rank}</div>${lyTag}<img class="card-img" src="${purl(item[CA],item[CC])}" loading="lazy" onerror="this.style.display='none'"></div><div class="card-body"><div class="card-ref">${item[CA]} · ${item[CC]}</div><div class="card-name">${item[CN]}</div><div class="card-stats"><div><div class="sl">${mode==="wc"?"LY WK19+20":"TY WK18"}</div><div class="sv ${ec}">${fmt(eur)}</div></div><div style="text-align:right"><div class="sl">Units</div><div class="sv un">${fmtI(un)}</div></div></div></div><div class="card-bar"><div class="${bc}" style="width:${pct}%"></div></div></div>`;
}
function updateSummary(label,eur,units){
  const u=units>0?`<span>Units: <strong>${fmtI(units)}</strong></span>`:"";
  el("summary").innerHTML=`<span>View: <strong>${label}</strong></span><span>Market: <strong>${curSexo==="HOMBRE"?"MEN":"WOMEN"}</strong></span><span>Total €: <strong>${fmt(eur)} €</strong></span>${u}`;
}
function updateSpark(items,mode,compact){
  const ei=compact?(mode==="wc"?CEL:CET):(mode==="wc"?EL:ET);
  const vals=items.map(i=>i[ei]),maxE=vals.length?vals[0]:1;
  const col=mode==="wc"?"var(--wc)":curSexo==="HOMBRE"?"var(--ah)":"var(--am)";
  el("sbars").innerHTML=vals.map((v,i)=>{const p=Math.max(Math.round((v/maxE)*100),4);return `<div class="sbar" style="height:${p}%;background:${col};opacity:${0.35+p/130}" data-tip="#${i+1} ${items[i][compact?CA:A]} · ${fmt(v)}€"></div>`;}).join("");
}
function buildLegend(mode,isH){
  const col=mode==="wc"?"var(--wc)":isH?"var(--ah)":"var(--am)";
  return `<span><span class="ldot" style="background:${col}"></span>Families driving 80% of sales</span><span><span class="ldot" style="background:#444"></span>Remaining families</span><span style="color:var(--mu);margin-left:auto;font-size:9px">↕ Click to expand</span>`;
}
function buildFamHTML(fams,mode,isH,compact){
  const tagCls=mode==="wc"?"tag-wc":isH?"tag-h":"tag-m";
  const hdrCls=mode==="wc"?"p80wc":isH?"p80h":"p80m";
  const maxFam=fams.length?(mode==="wc"?fams[0][FEL]:fams[0][FET]):1;
  let html="";
  fams.forEach(fam=>{
    const eur=mode==="wc"?fam[FEL]:fam[FET],eurO=mode==="wc"?fam[FET]:fam[FEL];
    const lbl=mode==="wc"?"LY WK19+20":"TY WK18",lblO=mode==="wc"?"TY WK18":"LY WK19+20";
    const pctFill=Math.round((eur/maxFam)*100),is80=fam[FI80];
    const pctCol=mode==="wc"?"var(--wc)":isH?"var(--ah)":"var(--am)";
    const bgCol=mode==="wc"?"rgba(52,211,153,.04)":isH?"rgba(232,196,74,.04)":"rgba(232,74,122,.04)";
    const tag=is80?`<span class="fam-tag ${tagCls}">TOP 80%</span>`:"";
    window._maxEur=fam[FIT].length?(mode==="wc"?fam[FIT][0][compact?CEL:EL]:fam[FIT][0][compact?CET:ET]):1;
    const cards=fam[FIT].map((it,i)=>compact?cardCompact(it,i+1,isH,mode):cardFull(it,i+1,isH,mode)).join("");
    html+=`<div class="fam-sec"><div class="fam-hdr${is80?" "+hdrCls:""}" onclick="toggleFam(this)"><div class="fam-bg" style="width:${pctFill}%;background:${is80?bgCol:"rgba(255,255,255,.01)"}"></div><div class="fam-left"><div class="fam-name${is80?"":" dim"}">${fam[FF]}</div><div class="fam-meta"><div class="fam-pct" style="color:${is80?pctCol:"var(--mu)"}">${fam[FPCT]}% of channel</div>${tag}</div></div><div class="fam-right"><div><div class="sl">${lbl}</div><div class="fam-eur" style="color:${is80?pctCol:"var(--mu)"}">${fmt(eur)} €</div><div class="fam-eur2">${lblO}: ${fmt(eurO)} €</div></div><div class="tog">▼</div></div></div><div class="fam-body"><div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(165px,1fr))">${cards}</div></div></div>`;
  });
  return html||"<div class=no-data>No data</div>";
}
function renderStore(){
  const inner=el("store-inner");
  if(!curStore){inner.innerHTML="<div class=no-store>Select a store to see its ranking</div>";el("summary").style.display="none";showSpark(false);showCB(false);return;}
  const st=DATA.st[curStore];if(!st)return;
  const isH=storeSexo==="HOMBRE",stData=st[storeSexo],mc=isH?"":" m";
  el("summary").style.display="flex";
  const sexoHtml=`<div class="store-controls"><div class="btn-grp"><button class="btn ${isH?"on-h":""}" onclick="setStoreSexo('HOMBRE')">▲ MEN</button><button class="btn ${!isH?"on-m":""}" onclick="setStoreSexo('MUJER')">♀ WOMEN</button></div><div class="badge ${isH?"bh":"bm"}" style="margin-left:auto">${isH?"MEN":"WOMEN"}</div><button class="pdf-btn" onclick="doPrint()">⬇ PDF</button></div>`;
  const subTabHtml=`<div class="store-subtabs"><div class="stab${storeTab==="top20"?" active"+mc:""}" onclick="setStoreTab('top20')">Top 20</div><div class="stab${storeTab==="family"?" active"+mc:""}" onclick="setStoreTab('family')">By Family — WK18</div><div class="stab${storeTab==="wc"?" active wc":""}" onclick="setStoreTab('wc')">▶ What's Coming WK19+20</div></div>`;
  showCB(storeTab==="wc");
  if(storeTab==="top20"){
    showSpark(true);
    const items=stData?stData.t||[]:[]; window._maxEur=items.length?items[0][CET]:1;
    inner.innerHTML=sexoHtml+subTabHtml+`<div class="grid">${items.length?items.map((it,i)=>cardCompact(it,i+1,isH,"ty")).join(""):"<div class=no-data>No sales this week</div>"}</div>`;
    const tot=items.reduce((s,i)=>s+i[CET],0),tou=items.reduce((s,i)=>s+i[CUT],0);
    el("summary").innerHTML=`<span>Store: <strong>${st.n}</strong></span><span>Market: <strong>${isH?"MEN":"WOMEN"}</strong></span><span>Total €: <strong>${fmt(tot)} €</strong></span><span>Units: <strong>${fmtI(tou)}</strong></span>`;
    updateSpark(items,"ty",true);
  }else if(storeTab==="family"){
    showSpark(false);
    const fams=stData?stData.f||[]:[]; 
    inner.innerHTML=sexoHtml+subTabHtml+`<div class="fam-legend">${buildLegend("ty",isH)}</div><div>${buildFamHTML(fams,"ty",isH,true)}</div>`;
    const tot=fams.reduce((s,f)=>s+f[FET],0);
    el("summary").innerHTML=`<span>Store: <strong>${st.n}</strong></span><span>Market: <strong>${isH?"MEN":"WOMEN"}</strong></span><span>Total €: <strong>${fmt(tot)} €</strong></span>`;
  }else if(storeTab==="wc"){
    showSpark(false);
    const fams=stData?stData.w||[]:[]; 
    inner.innerHTML=sexoHtml+subTabHtml+`<div class="fam-legend">${buildLegend("wc",isH)}</div><div>${buildFamHTML(fams,"wc",isH,true)}</div>`;
    const tot=fams.reduce((s,f)=>s+f[FEL],0);
    el("summary").innerHTML=`<span>Store: <strong>${st.n}</strong></span><span>Market: <strong>${isH?"MEN":"WOMEN"}</strong></span><span>LY WK19+20 €: <strong>${fmt(tot)} €</strong></span>`;
  }
}
function render(){
  const isH=curSexo==="HOMBRE",lbl=CHL[curChannel]||curChannel;
  if(curView==="channel"){
    showSpark(true);showCB(false);el("summary").style.display="flex";
    const items=(DATA.ch[curChannel]&&DATA.ch[curChannel][curSexo])||[];
    window._maxEur=items.length?items[0][ET]:1;
    el("grid-ch").innerHTML=items.length?items.map((it,i)=>cardFull(it,i+1,isH,"ty")).join(""):"<div class=no-data>No data</div>";
    const tot=items.reduce((s,i)=>s+i[ET],0),tou=items.reduce((s,i)=>s+i[UT],0);
    updateSummary(lbl,tot,tou);updateSpark(items,"ty",false);
    el("ptitle").textContent="TOP 20 · WK18 · "+lbl;
    el("pmeta").textContent="Market: "+(isH?"MEN":"WOMEN")+" · Channel: "+lbl;
  }else if(curView==="family"){
    showSpark(false);showCB(false);el("summary").style.display="flex";
    const fams=(DATA.fty[curChannel]&&DATA.fty[curChannel][curSexo])||[];
    el("fleg").innerHTML=buildLegend("ty",isH);el("fam-secs").innerHTML=buildFamHTML(fams,"ty",isH,false);
    const tot=fams.reduce((s,f)=>s+f[FET],0);
    updateSummary("Families WK18 · "+lbl,tot,0);
    el("ptitle").textContent="FAMILIES · WK18 · "+lbl;
  }else if(curView==="coming"){
    showSpark(false);showCB(true);el("summary").style.display="flex";
    const fams=(DATA.wc[curChannel]&&DATA.wc[curChannel][curSexo])||[];
    el("cleg").innerHTML=buildLegend("wc",isH);el("coming-secs").innerHTML=buildFamHTML(fams,"wc",isH,false);
    const tot=fams.reduce((s,f)=>s+f[FEL],0);
    updateSummary("What's Coming WK19+20 · "+lbl,tot,0);
    el("ptitle").textContent="WHATS COMING · WK19+20 LY · "+lbl;
  }else if(curView==="store"){
    renderStore();
  }
}
function toggleFam(h){const b=h.nextElementSibling,t=h.querySelector(".tog");b.classList.toggle("open");t.style.transform=b.classList.contains("open")?"rotate(180deg)":"";}
function doPrint(){document.querySelectorAll(".fam-body").forEach(b=>b.classList.add("open"));window.print();}
if(DATA.sl){const sel=document.getElementById("store-select");DATA.sl.forEach(s=>{const o=document.createElement("option");o.value=s.id;o.textContent=s.name;sel.appendChild(o);});}
switchView("channel");
</script>
</body>
</html>
